ADMIN_PASSWORD=replace-with-a-strong-password
AUTH_SECRET=replace-with-a-long-random-random-string
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Production-only image base URL (Cloudinary folder root)
# Example: https://res.cloudinary.com/<cloud-name>/image/upload/assets/brand
NEXT_PUBLIC_MEDIA_CLOUDINARY_BASE_URL=

# Optional production-only video base URL (defaults to NEXT_PUBLIC_MEDIA_CLOUDINARY_BASE_URL)
# Example: https://res.cloudinary.com/<cloud-name>/video/upload/assets/brand
NEXT_PUBLIC_MEDIA_CLOUDINARY_VIDEO_BASE_URL=

# Optional per-file overrides
# Home background video example:
# https://res.cloudinary.com/<cloud-name>/video/upload/assets/brand/home_page_background.mov
NEXT_PUBLIC_MEDIA_HOME_BACKGROUND_URL=
NEXT_PUBLIC_MEDIA_GALLERY_IMAGE_1_URL=
NEXT_PUBLIC_MEDIA_GALLERY_IMAGE_2_URL=
NEXT_PUBLIC_MEDIA_GALLERY_IMAGE_3_URL=
NEXT_PUBLIC_MEDIA_GALLERY_IMAGE_4_URL=
NEXT_PUBLIC_MEDIA_GALLERY_IMAGE_5_URL=
NEXT_PUBLIC_MEDIA_GALLERY_IMAGE_6_URL=
NEXT_PUBLIC_MEDIA_CA_MAP_URL=