ADMIN_PASSWORD=replace-with-a-strong-password
AUTH_SECRET=replace-with-a-long-random-random-string
BLOB_READ_WRITE_TOKEN=

# Optional: set this to your Blob folder root for brand media
# Example: https://<your-blob-store>.public.blob.vercel-storage.com/assets/brand
NEXT_PUBLIC_MEDIA_BASE_URL=

# Optional: per-file overrides (take priority over NEXT_PUBLIC_MEDIA_BASE_URL)
NEXT_PUBLIC_MEDIA_HOME_BACKGROUND_URL=
NEXT_PUBLIC_MEDIA_GALLERY_IMAGE_1_URL=
NEXT_PUBLIC_MEDIA_GALLERY_IMAGE_2_URL=
NEXT_PUBLIC_MEDIA_GALLERY_IMAGE_3_URL=
NEXT_PUBLIC_MEDIA_GALLERY_IMAGE_4_URL=
NEXT_PUBLIC_MEDIA_GALLERY_IMAGE_5_URL=
NEXT_PUBLIC_MEDIA_GALLERY_IMAGE_6_URL=
NEXT_PUBLIC_MEDIA_CA_MAP_URL=

# Legacy vars still supported in code for backward compatibility:
# NEXT_PUBLIC_MEDIA_GALLERY_VIDEO_1_URL .. NEXT_PUBLIC_MEDIA_GALLERY_VIDEO_5_URL